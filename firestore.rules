rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Extrair CPF do email de auth (formato: cpf@t7system.local)
    function getCPF() {
      return request.auth.token.email.split('@')[0];
    }

    function isAdmin() {
      return getCPF() == '00000000000';
    }

    // Dados por usuário — cada cliente vê só os seus
    match /dados_usuario/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || isAdmin());
    }

    // Sócios da empresa por usuário
    match /socios_empresa/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || isAdmin());
    }

    // Configs do sistema — só gerência
    match /sistema/{doc} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
