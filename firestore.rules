rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getCPF() {
      return request.auth.token.email != null
        ? request.auth.token.email.split('@')[0]
        : null;
    }

    function isAdmin() {
      return getCPF() == '00000000000';
    }

    function isAutenticado() {
      return request.auth != null;
    }

    // Lista de usuários — qualquer autenticado (incluindo anônimo)
    // Segurança: dados são criptografados client-side (AES-256-GCM)
    match /sistema/{doc} {
      allow read, write: if isAutenticado();
    }

    // Dados por usuário — qualquer autenticado pode ler/escrever
    // Segurança: dados são criptografados client-side
    // O controle de acesso (cliente vê só os seus) é feito no app
    match /dados_usuario/{cpf} {
      allow read, write: if isAutenticado();
    }

    // Sócios da empresa — mesmo modelo
    match /socios_empresa/{cpf} {
      allow read, write: if isAutenticado();
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
