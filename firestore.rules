rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Extrai o identificador do usuário do Firebase Auth (CPF ou CNPJ)
    // Login cria email como cpf@t7system.local ou cnpj@t7system.local
    function getIdUsuario() {
      return request.auth.token.email != null
        ? request.auth.token.email.split('@')[0]
        : null;
    }

    function isAutenticado() {
      return request.auth != null;
    }

    // Admin (CPF 00000000000) tem acesso total para gerenciar o sistema
    function isAdmin() {
      return getIdUsuario() == '00000000000';
    }

    // O próprio usuário OU o admin pode acessar
    function isProprietarioOuAdmin(docId) {
      return isAutenticado() && (getIdUsuario() == docId || isAdmin());
    }

    // Lista de usuários — qualquer autenticado pode ler
    match /sistema/{doc} {
      allow read: if isAutenticado();
      allow write: if isAutenticado();
    }

    // Dados por usuário — próprio usuário OU admin acessa
    // O docId é o CPF ou CNPJ do proprietário
    match /dados_usuario/{docId} {
      allow read, write: if isProprietarioOuAdmin(docId);
    }

    // Sócios da empresa — próprio usuário OU admin acessa
    match /socios_empresa/{docId} {
      allow read, write: if isProprietarioOuAdmin(docId);
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
