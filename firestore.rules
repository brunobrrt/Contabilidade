rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getCPF() {
      return request.auth.token.email.split('@')[0];
    }

    // Dados por usuário — cliente vê só os seus, gerência vê tudo
    match /dados_usuario/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || getCPF() == '00000000000');
    }

    // Sócios da empresa por usuário
    match /socios_empresa/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || getCPF() == '00000000000');
    }

    // Configs do sistema — qualquer usuário autenticado (app controla acesso por role)
    match /sistema/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
