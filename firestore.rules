rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // REGRAS DE SEGURANÇA — Sistema de Contabilidade T7
    //
    // Autenticação: Firebase Anonymous Auth (automático no app)
    // Qualquer request autenticado (token válido) pode ler/escrever.
    // Dados sensíveis são criptografados client-side (AES-256-GCM).
    // ============================================================

    match /{document=**} {
      // Permitir acesso apenas para requests autenticados
      // (Anonymous Auth gera token válido automaticamente)
      // Bloqueia acesso REST API direto SEM token
      allow read, write: if request.auth != null;
    }
  }
}
