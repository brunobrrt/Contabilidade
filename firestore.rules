rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Extrai o identificador do usuário do Firebase Auth (CPF ou CNPJ)
    // Login cria email como cpf@t7system.local ou cnpj@t7system.local
    function getIdUsuario() {
      return request.auth.token.email != null
        ? request.auth.token.email.split('@')[0]
        : null;
    }

    function isAutenticado() {
      return request.auth != null;
    }

    // Lista de usuários — qualquer autenticado pode ler
    // Escrita: só o próprio usuário pode escrever seus dados
    // Segurança adicional: dados são criptografados client-side (AES-256-GCM)
    match /sistema/{doc} {
      allow read: if isAutenticado();
      allow write: if isAutenticado();
    }

    // Dados por usuário — só o próprio usuário acessa
    // O docId é o CPF ou CNPJ do proprietário
    match /dados_usuario/{docId} {
      allow read, write: if isAutenticado() && getIdUsuario() == docId;
    }

    // Sócios da empresa — só o próprio usuário acessa
    match /socios_empresa/{docId} {
      allow read, write: if isAutenticado() && getIdUsuario() == docId;
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
