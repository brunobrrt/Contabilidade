rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getCPF() {
      return request.auth.token.email.split('@')[0];
    }

    function isGerencia() {
      return request.auth.token.role == 'gerencia';
    }

    // Dados por usuário — cliente vê só os seus, gerência vê tudo
    match /dados_usuario/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || isGerencia());
    }

    // Sócios da empresa por usuário
    match /socios_empresa/{cpf} {
      allow read, write: if request.auth != null
        && (getCPF() == cpf || isGerencia());
    }

    // Configs do sistema — só gerência
    match /sistema/{doc} {
      allow read, write: if request.auth != null && isGerencia();
    }

    // Bloquear resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
